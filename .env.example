# Configuración de Flask
FLASK_ENV=production
FLASK_APP=run:app
SECRET_KEY=tu-clave-secreta-aqui-cambiar-en-produccion

# Configuración de Base de Datos
# Railway inyecta DATABASE_URL automáticamente
# Para desarrollo local:
# DATABASE_URL=sqlite:///incidencias.db

# Configuración de Email (OPCIONAL - si no se configura, los emails se silencian)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=tu-email@gmail.com
MAIL_PASSWORD=tu-contraseña-de-app-gmail

# Configuración de Administrador
ADMIN_USERNAME=admin
ADMIN_PASSWORD=tu-contraseña-segura-aqui

# Puerto (Railway lo inyecta automáticamente como PORT)
# PORT=8080
